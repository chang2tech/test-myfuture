# myFUTURE — Environment Variables
# Copy to .env and adjust as needed

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development

# ── Client (Next.js) ─────────────────────────────────────────
CLIENT_PORT=3721
API_URL=http://localhost:4721/api
NEXT_PUBLIC_API_URL=http://localhost:4721/api
NEXT_PUBLIC_API_ORIGIN=http://localhost:4721
NEXT_PUBLIC_SITE_URL=http://localhost:3721

# ── Server (NestJS) ──────────────────────────────────────────
SERVER_PORT=4721
PORT=4721
CORS_ORIGINS=http://localhost:3721
CLIENT_URL=http://localhost:3721

# ── PostgreSQL (custom port 54321 to avoid conflicts) ────────
POSTGRES_USER=myfuture
POSTGRES_PASSWORD=myfuture_secret_2026
POSTGRES_DB=myfuture
POSTGRES_PORT=54321
DATABASE_URL=postgresql://myfuture:myfuture_secret_2026@localhost:54321/myfuture?schema=public

# ── Redis (custom port 6380 to avoid conflicts) ────────────────
REDIS_PORT=6380
REDIS_HOST=localhost
REDIS_PASSWORD=

# ── Docker internal URLs (used inside docker-compose) ────────
# DATABASE_URL=postgresql://myfuture:myfuture_secret_2026@postgres:5432/myfuture?schema=public
# REDIS_HOST=redis
# REDIS_PORT=6379
