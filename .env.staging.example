# myFUTURE — Staging (VPS 116.118.6.129 / myfuture.changtotech.click)
# Copy to /opt/myfuture/.env trên VPS

NODE_ENV=production

# ── Public URLs (HTTPS qua aaPanel reverse proxy) ─────────────
CLIENT_URL=https://myfuture.changtotech.click
CORS_ORIGINS=https://myfuture.changtotech.click
NEXT_PUBLIC_SITE_URL=https://myfuture.changtotech.click
NEXT_PUBLIC_API_ORIGIN=https://myfuture.changtotech.click
NEXT_PUBLIC_API_URL=https://myfuture.changtotech.click/api

# SSR nội bộ Docker (client container → server container)
API_URL=http://server:4721/api

# ── Nginx (aaPanel reverse proxy → 127.0.0.1:8090) ──────────
NGINX_PORT=8090
IMAGE_REGISTRY=ghcr.io/chang2tech
APP_VERSION=latest

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=myfuture
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=myfuture

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth / Admin ─────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING
JWT_EXPIRES_IN=7d
DEV_ADMIN_EMAIL=admin@myfuture.vn
DEV_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
UPLOAD_DIR=uploads/articles
