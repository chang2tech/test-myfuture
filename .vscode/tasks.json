{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Client",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "presentation": {
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Server",
      "type": "shell",
      "command": "npm run start:dev",
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "presentation": {
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Dev",
      "dependsOn": ["Client", "Server"],
      "dependsOrder": "parallel",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
