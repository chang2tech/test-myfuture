{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Stop Docker App",
      "type": "shell",
      "command": "docker compose stop client server 2>/dev/null || true",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "Start DB (Docker)",
      "type": "shell",
      "command": "docker compose up postgres redis -d",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Start Client",
      "type": "shell",
      "command": "npm run dev",
      "dependsOn": ["Stop Docker App"],
      "options": {
        "cwd": "${workspaceFolder}/client"
      },
      "presentation": {
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "Start Server",
      "type": "shell",
      "command": "npm run start:dev",
      "dependsOn": ["Stop Docker App", "Start DB (Docker)"],
      "options": {
        "cwd": "${workspaceFolder}/server"
      },
      "presentation": {
        "panel": "dedicated",
        "group": "dev"
      }
    },
    {
      "label": "🚀 Dev All (Local)",
      "dependsOn": ["Start Client", "Start Server"],
      "dependsOrder": "parallel",
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "🐳 Dev All (Docker)",
      "type": "shell",
      "command": "docker compose up --build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "panel": "dedicated",
        "group": "dev"
      }
    }
  ]
}
